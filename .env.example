TELEGRAM_BOT_TOKEN=your_bot_token_here

BUKHARA_REGOS_AUTH_PHONE=+998000000001
BUKHARA_REGOS_AUTH_PASSWORD=your_bukhara_password

SAMARKAND_REGOS_AUTH_PHONE=+998000000002
SAMARKAND_REGOS_AUTH_PASSWORD=your_samarkand_password

# Chayxanshik RPOS (Django admin) — optional per account
# SAMARKAND_RPOS_USERNAME=timur
# SAMARKAND_RPOS_PASSWORD=your_rpos_password
# BUKHARA_RPOS_USERNAME=
# BUKHARA_RPOS_PASSWORD=

# Bot admin panel (/bot-admin/) — manage employees and rights
BOT_ADMIN_LOGIN=admin
BOT_ADMIN_PASSWORD=change_me

# CLICK payment integration
CLICK_MERCHANT_ID=your_click_merchant_id
CLICK_SERVICE_ID=your_click_service_id
CLICK_MERCHANT_USER_ID=your_click_merchant_user_id
CLICK_SECRET_KEY=your_click_secret_key
CLICK_RETURN_URL=https://aserver.tech/example-order-id
CLICK_SERVER_PORT=3000
PUBLIC_BASE_URL=https://aserver.tech

# Payme Subscribe API (receipts — no webhook required)
PAYME_MERCHANT_ID=your_merchant_id_from_cabinet
PAYME_SECRET_KEY=your_key_from_cabinet
PAYME_TEST_KEY=your_sandbox_test_key
PAYME_TEST_MODE=0
# Optional receipt freshness window (default 12h)
# PAYME_RECEIPT_TTL_MS=43200000
# Optional: set to 1 to show CLICK button on payment page (hidden by default)
# ENABLE_CLICK_PAYMENT=0

# SMS gateway (Redis queue + Android WebSocket app — skipped when REDIS_URL unset)
REDIS_URL=redis://127.0.0.1:6379
SMS_GATEWAY_TOKEN=change_me_long_random_secret
