<service>
	<id>scrapregosuserbot.exe</id>
	<name>ScrapRegosUserBot</name>
	<description>Regos user lookup Telegram bot</description>
	<executable>C:\Program Files\nodejs\node.exe</executable>
	<argument>--harmony</argument>
	<argument>C:\Projects\ScrapRegosUserBot\node_modules\node-windows\lib\wrapper.js</argument>
	<argument>--file</argument>
	<argument>C:\Projects\ScrapRegosUserBot\bot.js</argument>
	<argument>--scriptoptions=</argument>
	<argument>--log</argument>
	<argument>ScrapRegosUserBot wrapper</argument>
	<argument>--grow</argument>
	<argument>0.25</argument>
	<argument>--wait</argument>
	<argument>2</argument>
	<argument>--maxrestarts</argument>
	<argument>10</argument>
	<argument>--abortonerror</argument>
	<argument>n</argument>
	<argument>--stopparentfirst</argument>
	<argument>undefined</argument>
	<logmode>rotate</logmode>
	<logpath>C:\Projects\ScrapRegosUserBot\logs</logpath>
	<stoptimeout>30sec</stoptimeout>
	<env name="NODE_ENV" value="production"/>
	<serviceaccount>
		<domain>SAMTECHFARIZ</domain>
		<user>LocalSystem</user>
		<password></password>
	</serviceaccount>
	<workingdirectory>C:\Projects\ScrapRegosUserBot</workingdirectory>
</service>